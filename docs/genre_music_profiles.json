            "Bass": { "hpf_max_hz": 30, "resonance_reduction_max_db": -2.5, "masking_tolerance": 0.7 },
            "Lead Synth": { "hpf_max_hz": 80, "resonance_reduction_max_db": -2.5, "masking_tolerance": 0.5, "presence_boost_max_db": 3.0 },
            "Pad/Drone": { "hpf_max_hz": 80, "resonance_reduction_max_db": -3.0, "masking_tolerance": 0.4 }
          }
        }
      }
