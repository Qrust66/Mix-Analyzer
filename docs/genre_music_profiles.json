{
  "_version": "1.0",
  "_description": "Profils de calibration par genre musical et type de track pour l'orchestrateur Mix Analyzer. Les valeurs représentent les réglages à 100% d'intensité (standard pour le genre).",

  "_track_types_reference": {
    "drums": ["Kick", "Snare/Clap", "Hi-Hat/Cymbal", "Tom", "Percussion", "Drum Loop/Bus"],
    "bass": ["Sub Bass", "Bass", "Acid Bass", "808/Pitched Bass"],
    "synth": ["Lead Synth", "Pluck/Stab", "Pad/Drone", "Arpeggio/Sequence", "Texture/Atmosphere"],
    "guitar": ["Guitar Clean", "Guitar Distorted", "Guitar Acoustic"],
    "vocal": ["Lead Vocal", "Backing/Harmony Vocal", "Vocal FX/Chop"],
    "fx": ["FX/Riser/Impact", "Noise/Ambience", "Sample/Loop", "Other"]
  },

  "_spectrum_poles": {
    "description": "Certains genres couvrent un spectre esthétique large. Le paramètre 'character' (0.0–1.0) positionne le projet sur ce spectre.",
    "0.0": "Abrasif — mud voulu, saturation = le son, résonances = agressivité, chaos stéréo",
    "0.5": "Équilibré — propre mais texturé, définition sans stérilisation",
    "1.0": "Atmosphérique — clarté, espace, subtilité, résonances = émotion"
  },

  "families": {

    "electronic_aggressive": {
      "description": "Industrial, Bass Music (Dubstep, DnB), Synthwave/Retrowave",
      "default_character": 0.3,
      "styles": {

        "Industrial": {
          "description": "NIN, Ministry, KMFDM, Author & Punisher. Sub saturé, transients durs, distortion structurelle.",
          "default_character": 0.2,
          "default_intensity": {
            "gain_staging": 1.0,
            "hpf_lpf": 0.7,
            "resonances": 0.5,
            "masking": 0.5,
            "dynamics": 0.4,
            "polish": 0.3
          },
          "track_profiles": {
            "Kick": {
              "hpf_max_hz": 30,
              "lpf_min_hz": 12000,
              "resonance_reduction_max_db": -3.0,
              "masking_tolerance": 0.7,
              "transient_preserve": true,
              "notes": "Kick industriel = gras, claqué, sale. Le transient 2-5 kHz est sacré. Ne pas aseptiser."
            },
            "Snare/Clap": {
              "hpf_max_hz": 80,
              "resonance_reduction_max_db": -4.0,
              "masking_tolerance": 0.5,
              "transient_preserve": true,
              "notes": "Snare peut être bruité, layered, saturé. Nettoyer le sub inutile, préserver l'agression."
            },
            "Hi-Hat/Cymbal": {
              "hpf_max_hz": 200,
              "lpf_min_hz": 18000,
              "resonance_reduction_max_db": -4.0,
              "masking_tolerance": 0.4,
              "notes": "HPF agressif OK. Résonances métalliques souvent voulues mais pas le mud."
            },
            "Tom": {
              "hpf_max_hz": 60,
              "resonance_reduction_max_db": -4.0,
              "masking_tolerance": 0.5,
              "transient_preserve": true,
              "notes": "Toms industriels = body + attaque. Nettoyer les résonances de fût sans tuer le sustain."
            },
            "Percussion": {
              "hpf_max_hz": 100,
              "resonance_reduction_max_db": -5.0,
              "masking_tolerance": 0.4,
              "notes": "Percussion texturale. Nettoyage plus agressif acceptable."
            },
            "Drum Loop/Bus": {
              "skip_corrections": true,
              "notes": "Corriger les sources, pas les bus."
            },
            "Sub Bass": {
              "hpf_max_hz": 20,
              "lpf_min_hz": 200,
              "resonance_reduction_max_db": -2.0,
              "masking_tolerance": 0.8,
              "notes": "Fondation. Toucher avec extrême précaution. Le sub distordu EST le son."
            },
            "Bass": {
              "hpf_max_hz": 30,
              "lpf_min_hz": 5000,
              "resonance_reduction_max_db": -2.5,
              "masking_tolerance": 0.7,
              "notes": "Harmoniques basses sont critiques. Résonances peuvent être voulues pour l'agression."
            },
            "Acid Bass": {
              "hpf_max_hz": 25,
              "lpf_min_hz": 8000,
              "resonance_reduction_max_db": -2.0,
              "masking_tolerance": 0.7,
              "notes": "Le filtre résonant EST le son. Ne pas tuer les peaks de résonance du 303/acid — c'est l'âme du patch."
            },
            "808/Pitched Bass": {
              "hpf_max_hz": 20,
              "lpf_min_hz": 3000,
              "resonance_reduction_max_db": -2.0,
              "masking_tolerance": 0.8,
              "notes": "Fondamentale + harmoniques basses. Structure similaire à Sub Bass mais avec plus de mid content."
            },
            "Lead Synth": {
              "hpf_max_hz": 80,
              "resonance_reduction_max_db": -3.0,
              "masking_tolerance": 0.5,
              "presence_boost_max_db": 2.5,
              "notes": "Présence 2-5 kHz critique. Ne pas castrer le mid-range. Résonances peuvent être du character."
            },
            "Pluck/Stab": {
              "hpf_max_hz": 100,
              "resonance_reduction_max_db": -3.5,
              "masking_tolerance": 0.5,
              "transient_preserve": true,
              "notes": "Transient d'attaque important. Decay peut accumuler du mud — nettoyable."
            },
            "Pad/Drone": {
              "hpf_max_hz": 100,
              "resonance_reduction_max_db": -4.0,
              "masking_tolerance": 0.3,
              "notes": "Background. Nettoyage agressif OK. Le pad doit remplir sans dominer."
            },
            "Arpeggio/Sequence": {
              "hpf_max_hz": 80,
              "resonance_reduction_max_db": -3.5,
              "masking_tolerance": 0.4,
              "notes": "Mouvement répétitif = accumulation fréquentielle. Notch dynamique très pertinent."
            },
            "Texture/Atmosphere": {
              "hpf_max_hz": 120,
              "resonance_reduction_max_db": -5.0,
              "masking_tolerance": 0.3,
              "notes": "Rôle = espace et profondeur. Nettoyage agressif OK, ne doit pas masquer les éléments principaux."
            },
            "Guitar Distorted": {
              "hpf_max_hz": 80,
              "lpf_min_hz": 10000,
              "resonance_reduction_max_db": -3.0,
              "masking_tolerance": 0.5,
              "notes": "Guitare industrielle = saturée, mid-heavy. Couper le sub mais préserver l'agression 1-4 kHz."
            },
            "Guitar Clean": {
              "hpf_max_hz": 100,
              "resonance_reduction_max_db": -3.5,
              "masking_tolerance": 0.4,
              "notes": "Rare en industrial mais possible. Nettoyer normalement."
            },
            "Guitar Acoustic": {
              "hpf_max_hz": 80,
              "resonance_reduction_max_db": -3.0,
              "masking_tolerance": 0.5,
              "notes": "Body 200-400 Hz important. Ne pas over-HPF."
            },
            "Lead Vocal": {
              "hpf_max_hz": 80,
              "resonance_reduction_max_db": -2.5,
              "deess_threshold_db": -22,
              "deess_reduction_db": -3.0,
              "presence_boost_max_db": 2.0,
              "masking_tolerance": 0.6,
              "notes": "Voix dark/industrial = souvent traitée, distordue. Ne pas overcleaner les sibilances. La rugosité est voulue."
            },
            "Backing/Harmony Vocal": {
              "hpf_max_hz": 120,
              "resonance_reduction_max_db": -3.0,
              "deess_threshold_db": -20,
              "masking_tolerance": 0.4,
              "notes": "Support. Peut être nettoyé plus agressivement que le lead."
            },
            "Vocal FX/Chop": {
              "hpf_max_hz": 150,
              "resonance_reduction_max_db": -4.0,
              "masking_tolerance": 0.3,
              "notes": "Texturale. Nettoyage agressif OK."
            },
            "FX/Riser/Impact": {
              "hpf_max_hz": 30,
              "resonance_reduction_max_db": -3.0,
              "masking_tolerance": 0.5,
              "notes": "Transitoire par nature. Le sub dans un impact/riser est souvent voulu. Attention au HPF."
            },
            "Noise/Ambience": {
              "hpf_max_hz": 150,
              "resonance_reduction_max_db": -6.0,
              "masking_tolerance": 0.2,
              "notes": "Pur background. Nettoyage très agressif. Ne doit jamais masquer quoi que ce soit."
            },
            "Sample/Loop": {
              "hpf_max_hz": 80,
              "resonance_reduction_max_db": -3.5,
              "masking_tolerance": 0.5,
              "notes": "Dépend du contenu. Réglages moyens par défaut."
            },
            "Other": {
              "hpf_max_hz": 80,
              "resonance_reduction_max_db": -3.0,
              "masking_tolerance": 0.5,
              "notes": "Non catégorisé. Réglages conservateurs."
            }
          }
        },

        "Bass Music": {
          "description": "Dubstep, DnB, Bass House. Sub dominant, mid-bass heavy, transients précis.",
