            "Pad/Drone": { "hpf_max_hz": 150, "resonance_reduction_max_db": -5.0, "masking_tolerance": 0.3 },
            "Noise/Ambience": { "hpf_max_hz": 200, "resonance_reduction_max_db": -6.0, "masking_tolerance": 0.2 }
